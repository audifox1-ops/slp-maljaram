rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: students
    // Fields:
    //   - name: string (required)
    //   - birthDate: string (required)
    //   - school: string (required)
    //   - disabilityType: string
    //   - treatmentArea: string (required)
    //   - schedule: map { day: string, time: string, frequency: string }
    //   - startDate: string
    //   - therapistName: string
    //   - voucherArea: string
    //   - paymentDates: list<string>
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.birthDate is string && data.birthDate.size() > 0 &&
             data.school is string && data.school.size() > 0 &&
             data.treatmentArea is string && data.treatmentArea.size() > 0;
    }

    match /students/{studentId} {
      // Allowing public access as requested for a private, limited-user app
      allow read, write: if true;
    }
  }
}
