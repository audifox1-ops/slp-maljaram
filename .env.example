# Gemini API Key
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Firebase Config (for slp-docs project)
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=slp-docs.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=slp-docs
VITE_FIREBASE_STORAGE_BUCKET=slp-docs.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
VITE_FIREBASE_DATABASE_ID=slp-docs
